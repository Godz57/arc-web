# Public site URL (SEO / sitemap)
NEXT_PUBLIC_SITE_URL=https://arcweb.com.br

# --- Contact uplink (Web3Forms recommended) ---
# Access key from https://web3forms.com — safe to expose (official design).
# Submit runs in the browser so Cloudflare doesn't block server IPs.
NEXT_PUBLIC_WEB3FORMS_KEY=

# Optional server fallback (may hit Cloudflare on some hosts):
# WEB3FORMS_ACCESS_KEY=

# Alternatives via /api/contact:
# FORMSPREE_ID=
# CONTACT_EMAIL=seu@email.com

# --- Public contact / social (CTA WhatsApp, footer) ---
# WhatsApp: digits only with country code, e.g. 5511999999999
NEXT_PUBLIC_WHATSAPP=
NEXT_PUBLIC_CONTACT_EMAIL=contato@arcweb.com.br
NEXT_PUBLIC_GITHUB=https://github.com/Godz57
NEXT_PUBLIC_LINKEDIN=https://www.linkedin.com/in/gabriel-lucas-a2662b421

# Google Search Console — HTML tag verification (content value only)
# Example meta: <meta name="google-site-verification" content="ABC..." />
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=ABC...

# Google Tag Manager — container ID (e.g. GTM-XXXXXXX)
# NEXT_PUBLIC_GTM_ID=GTM-KN4DLJ2W

# Google Analytics 4 — Measurement ID (Admin → Data streams → Web)
# Example: G-XXXXXXXXXX
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-CGLHP3YJXN

# Set to "true" only after GA4 is fired from GTM (disables direct gtag to avoid double hits)
# NEXT_PUBLIC_GA_VIA_GTM=false

# Optional Google Ads account tag (AW-XXXXXXXXX) — prefer importing conversions from GA4
# NEXT_PUBLIC_GOOGLE_ADS_ID=AW-XXXXXXXXX
